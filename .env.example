# TikTok profile watcher (sends alerts to configured chat/topic)
TIKTOK_WATCH_ENABLED=1
TIKTOK_WATCH_PROFILES=TPEBOP.FX|https://www.tiktok.com/@tpebop.fx;Влад|https://www.tiktok.com/@amb1tiousxd;Harimos|https://www.tiktok.com/@harimos.da;Mura|https://www.tiktok.com/@mura_am;HAYZ|https://www.tiktok.com/@hayz.officiall
# Backward-compatible single profile fallback:
# TIKTOK_WATCH_PROFILE_URL=https://www.tiktok.com/@tpebop.fx
# TIKTOK_WATCH_PROFILE_LABEL=TPEBOP.FX
TIKTOK_WATCH_POLL_SECONDS=120
TIKTOK_WATCH_TARGET_CHAT_ID=2033901364
# Optional forum topic id; leave 0 for General topic
TIKTOK_WATCH_TARGET_THREAD_ID=0

# NVIDIA NIM AI commentary for video captions
NIM_ENABLED=0
NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NIM_MODEL=meta/llama-3.3-70b-instruct
NIM_BASE_URL=https://integrate.api.nvidia.com/v1/chat/completions
NIM_TIMEOUT_SECONDS=12
NIM_MAX_COMMENT_CHARS=220
NIM_COMMENTARY_MODE=neutral
NIM_MAX_FRAMES=8
